{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aideo",
  "version": "0.7.5",
  "identifier": "com.alirul.music-player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aideo Music Player",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "aideo"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}